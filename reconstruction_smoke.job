#!/bin/bash
#SBATCH --job-name=recon_smoke
#SBATCH --output=%x_%j.out
#SBATCH --error=%x_%j.err
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=02:00:00

set -Eeuo pipefail

PROJECT_DIR="${PROJECT_DIR:-/scratch-shared/$USER/Explanation-of-GNN-using-LLM}"
CONDA_ENV="${CONDA_ENV:-ethfraud_clean}"

DATASET="${DATASET:-elliptic}"
MODEL="${MODEL:-GAT}"
LLM="${LLM:-Qwen/Qwen2.5-3B}"
EXPERIMENT="${EXPERIMENT:-reconstruction_1hop}"
NUM_TARGET_NODES="${NUM_TARGET_NODES:-1}"
TARGET_NODE_POOL="${TARGET_NODE_POOL:-test}"
NUM_HOPS="${NUM_HOPS:-2}"
EXTRACT_WORKERS="${EXTRACT_WORKERS:-1}"
DEVICE="${DEVICE:-cuda}"
SEED="${SEED:-42}"
MAX_NEW_TOKENS="${MAX_NEW_TOKENS:-128}"
LLM_BATCH_SIZE="${LLM_BATCH_SIZE:-1}"
SMOKE_TIMEOUT="${SMOKE_TIMEOUT:-45m}"
MAX_CANDIDATES="${MAX_CANDIDATES:-20}"
CANDIDATE_CONTEXT_MODE="${CANDIDATE_CONTEXT_MODE:-pca}"
CANDIDATE_PCA_COMPONENTS="${CANDIDATE_PCA_COMPONENTS:-16}"
CANDIDATE_FEATURE_MAX_LENGTH="${CANDIDATE_FEATURE_MAX_LENGTH:-0}"
CANDIDATE_EMBEDDING_MAX_LENGTH="${CANDIDATE_EMBEDDING_MAX_LENGTH:-0}"
CONTINUE_ON_LLM_ERROR="${CONTINUE_ON_LLM_ERROR:-true}"

OUTPUT_DIR="${OUTPUT_DIR:-$PROJECT_DIR/outputs/recon_smoke_${SLURM_JOB_ID:-manual}}"

on_exit() {
    exit_code=$1
    echo "============================================================"
    echo "Smoke test finished with exit code: $exit_code"
    echo "Time: $(date)"
    echo "Output dir: $OUTPUT_DIR"
    echo "Slurm stdout: ${SLURM_SUBMIT_DIR:-$(pwd)}/${SLURM_JOB_NAME:-recon_smoke}_${SLURM_JOB_ID:-manual}.out"
    echo "Slurm stderr: ${SLURM_SUBMIT_DIR:-$(pwd)}/${SLURM_JOB_NAME:-recon_smoke}_${SLURM_JOB_ID:-manual}.err"
    if [ -d "$OUTPUT_DIR" ]; then
        echo "Output files:"
        find "$OUTPUT_DIR" -maxdepth 1 -type f -print | sort
    else
        echo "Output directory was not created."
    fi
    echo "============================================================"
}
trap 'on_exit $?' EXIT

echo "============================================================"
echo "Reconstruction smoke test"
echo "Job id: ${SLURM_JOB_ID:-manual}"
echo "Array id: ${SLURM_ARRAY_TASK_ID:-none}"
echo "Host: $(hostname)"
echo "Start: $(date)"
echo "Project: $PROJECT_DIR"
echo "Dataset: $DATASET"
echo "Model: $MODEL"
echo "LLM: $LLM"
echo "Experiment: $EXPERIMENT"
echo "Targets: $NUM_TARGET_NODES"
echo "Max candidates per prompt: $MAX_CANDIDATES"
echo "Candidate context mode: $CANDIDATE_CONTEXT_MODE"
echo "Candidate PCA components: $CANDIDATE_PCA_COMPONENTS"
echo "Candidate feature max length: $CANDIDATE_FEATURE_MAX_LENGTH"
echo "Candidate embedding max length: $CANDIDATE_EMBEDDING_MAX_LENGTH"
echo "Continue on LLM error: $CONTINUE_ON_LLM_ERROR"
echo "Timeout: $SMOKE_TIMEOUT"
echo "============================================================"

cd "$PROJECT_DIR"
mkdir -p "$OUTPUT_DIR"

if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
    source "$HOME/miniconda3/etc/profile.d/conda.sh"
else
    echo "ERROR: Could not find conda.sh at $HOME/miniconda3/etc/profile.d/conda.sh" >&2
    exit 2
fi
conda activate "$CONDA_ENV"

export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-8}"
export MKL_NUM_THREADS="${SLURM_CPUS_PER_TASK:-8}"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"

export HF_HOME="${HF_HOME:-/scratch-shared/$USER/huggingface}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-$HF_HOME/transformers}"
export HF_DATASETS_CACHE="${HF_DATASETS_CACHE:-$HF_HOME/datasets}"
export HUGGINGFACE_HUB_CACHE="${HUGGINGFACE_HUB_CACHE:-$HF_HOME/hub}"
mkdir -p "$HF_HOME" "$TRANSFORMERS_CACHE" "$HF_DATASETS_CACHE" "$HUGGINGFACE_HUB_CACHE"

echo "Python: $(which python)"
python --version
echo "Working directory: $(pwd)"
echo "Disk usage for scratch:"
df -h "/scratch-shared/$USER" || true
echo "GPU info:"
nvidia-smi || true

CONTINUE_ON_ERROR_ARGS=()
case "${CONTINUE_ON_LLM_ERROR,,}" in
    1|true|yes|y)
        CONTINUE_ON_ERROR_ARGS=(--continue-on-llm-error)
        ;;
esac

echo "============================================================"
echo "Checking expected files"
echo "============================================================"
for path in \
    Final_version/main.py \
    Final_version/LLM_Module.py \
    Final_version/Extracion.py \
    Final_version/Evalueation.py
do
    if [ ! -f "$path" ]; then
        echo "ERROR: missing $path" >&2
        exit 3
    fi
    ls -lh "$path"
done

echo "============================================================"
echo "Python syntax check"
echo "============================================================"
python -m py_compile \
    Final_version/main.py \
    Final_version/LLM_Module.py \
    Final_version/Extracion.py \
    Final_version/Evalueation.py

echo "============================================================"
echo "Pipeline dry-run"
echo "============================================================"
python Final_version/main.py --dry-run \
    --datasets "$DATASET" \
    --models "$MODEL" \
    --llms "$LLM" \
    --experiments "$EXPERIMENT" \
    --num-target-nodes "$NUM_TARGET_NODES" \
    --target-node-pool "$TARGET_NODE_POOL" \
    --num-hops "$NUM_HOPS" \
    --extract-workers "$EXTRACT_WORKERS" \
    --device "$DEVICE" \
    --seed "$SEED" \
    --num-runs 1 \
    --max-new-tokens "$MAX_NEW_TOKENS" \
    --llm-batch-size "$LLM_BATCH_SIZE" \
    --reconstruction-max-candidates "$MAX_CANDIDATES" \
    --candidate-context-mode "$CANDIDATE_CONTEXT_MODE" \
    --candidate-pca-components "$CANDIDATE_PCA_COMPONENTS" \
    --candidate-feature-max-length "$CANDIDATE_FEATURE_MAX_LENGTH" \
    --candidate-embedding-max-length "$CANDIDATE_EMBEDDING_MAX_LENGTH" \
    "${CONTINUE_ON_ERROR_ARGS[@]}" \
    --output-dir "$OUTPUT_DIR"

echo "============================================================"
echo "Running reconstruction smoke test"
echo "============================================================"
RUN_PREFIX=()
if command -v timeout >/dev/null 2>&1; then
    RUN_PREFIX=(timeout "$SMOKE_TIMEOUT")
else
    echo "Warning: timeout command not found; running without timeout."
fi

"${RUN_PREFIX[@]}" python Final_version/main.py \
    --datasets "$DATASET" \
    --models "$MODEL" \
    --llms "$LLM" \
    --experiments "$EXPERIMENT" \
    --num-target-nodes "$NUM_TARGET_NODES" \
    --target-node-pool "$TARGET_NODE_POOL" \
    --num-hops "$NUM_HOPS" \
    --extract-workers "$EXTRACT_WORKERS" \
    --device "$DEVICE" \
    --seed "$SEED" \
    --num-runs 1 \
    --max-new-tokens "$MAX_NEW_TOKENS" \
    --llm-batch-size "$LLM_BATCH_SIZE" \
    --reconstruction-max-candidates "$MAX_CANDIDATES" \
    --candidate-context-mode "$CANDIDATE_CONTEXT_MODE" \
    --candidate-pca-components "$CANDIDATE_PCA_COMPONENTS" \
    --candidate-feature-max-length "$CANDIDATE_FEATURE_MAX_LENGTH" \
    --candidate-embedding-max-length "$CANDIDATE_EMBEDDING_MAX_LENGTH" \
    "${CONTINUE_ON_ERROR_ARGS[@]}" \
    --output-dir "$OUTPUT_DIR"

PROMPT_IO="$OUTPUT_DIR/llm_prompt_io_${EXPERIMENT}.json"
RAW_RESULTS="$OUTPUT_DIR/results_raw_${EXPERIMENT}.json"

echo "============================================================"
echo "Smoke output summary"
echo "============================================================"
if [ -f "$PROMPT_IO" ]; then
    echo "Found prompt I/O file: $PROMPT_IO"
    python - "$PROMPT_IO" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
rows = json.loads(path.read_text())
print(f"Prompt I/O rows: {len(rows)}")
if rows:
    prompt = rows[0].get("llm_input_prompt", "")
    print("First prompt preview:")
    print(prompt[:4000])
    print("--- contains Candidate node context:", "Candidate node context:" in prompt)
    print("--- contains raw feature signal:", ("raw_features=" in prompt) or ("raw_feature_cosine=" in prompt) or ("raw_feature_pca:" in prompt))
    print("--- contains embedding signal:", ("embedding=" in prompt) or ("embedding_cosine=" in prompt) or ("embedding_pca:" in prompt))
PY
else
    echo "ERROR: missing prompt I/O file: $PROMPT_IO" >&2
    exit 4
fi

if [ -f "$RAW_RESULTS" ]; then
    echo "Found raw results file: $RAW_RESULTS"
    python - "$RAW_RESULTS" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
rows = json.loads(path.read_text())
print(f"Raw result rows: {len(rows)}")
if rows:
    first = rows[0]
    print("First parsed neighbors:", first.get("predicted_neighbors"))
    print("First raw LLM response:")
    print(str(first.get("llm_raw_response", ""))[:2000])
PY
else
    echo "ERROR: missing raw results file: $RAW_RESULTS" >&2
    exit 5
fi

echo "Smoke test completed successfully."
