#!/bin/bash
#SBATCH --job-name=recon_multi_smoke
#SBATCH --output=%x_%j.out
#SBATCH --error=%x_%j.err
#SBATCH --partition=gpu_h100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=03:00:00

set -Eeuo pipefail

PROJECT_DIR="${PROJECT_DIR:-/scratch-shared/$USER/Explanation-of-GNN-using-LLM}"
CONDA_ENV="${CONDA_ENV:-ethfraud_clean}"

DATASETS="${DATASETS:-elliptic dgraphfin}"
MODELS="${MODELS:-GAT}"
LLMS="${LLMS:-Qwen/Qwen2.5-3B}"
EXPERIMENTS="${EXPERIMENTS:-reconstruction_1hop}"
NUM_TARGET_NODES="${NUM_TARGET_NODES:-1}"
TARGET_NODE_POOL="${TARGET_NODE_POOL:-test}"
TARGET_NODE_SAMPLING="${TARGET_NODE_SAMPLING:-random}"
NUM_HOPS="${NUM_HOPS:-2}"
EXTRACT_WORKERS="${EXTRACT_WORKERS:-1}"
DEVICE="${DEVICE:-cuda}"
SEED="${SEED:-42}"
MAX_NEW_TOKENS="${MAX_NEW_TOKENS:-128}"
LLM_BATCH_SIZE="${LLM_BATCH_SIZE:-1}"
THINKING_BUDGET="${THINKING_BUDGET:-}"
DISABLE_THINKING="${DISABLE_THINKING:-false}"
ENABLE_THINKING="${ENABLE_THINKING:-false}"
MAX_CANDIDATES="${MAX_CANDIDATES:-503}"
CANDIDATE_CONTEXT_MODE="${CANDIDATE_CONTEXT_MODE:-pca}"
CANDIDATE_PCA_COMPONENTS="${CANDIDATE_PCA_COMPONENTS:-16}"
SMOKE_TIMEOUT="${SMOKE_TIMEOUT:-2h}"
CONTINUE_ON_LLM_ERROR="${CONTINUE_ON_LLM_ERROR:-true}"
VERIFY_DATASETS="${VERIFY_DATASETS:-true}"

OUTPUT_DIR="${OUTPUT_DIR:-$PROJECT_DIR/outputs/recon_multi_dataset_smoke_${SLURM_JOB_ID:-manual}}"

read -r -a DATASET_ARGS <<< "$DATASETS"
read -r -a MODEL_ARGS <<< "$MODELS"
read -r -a LLM_ARGS <<< "$LLMS"
read -r -a EXPERIMENT_ARGS <<< "$EXPERIMENTS"

on_exit() {
    exit_code=$1
    echo "============================================================"
    echo "Multi-dataset smoke finished with exit code: $exit_code"
    echo "Time: $(date)"
    echo "Output dir: $OUTPUT_DIR"
    echo "Slurm stdout: ${SLURM_SUBMIT_DIR:-$(pwd)}/${SLURM_JOB_NAME:-recon_multi_smoke}_${SLURM_JOB_ID:-manual}.out"
    echo "Slurm stderr: ${SLURM_SUBMIT_DIR:-$(pwd)}/${SLURM_JOB_NAME:-recon_multi_smoke}_${SLURM_JOB_ID:-manual}.err"
    if [ -d "$OUTPUT_DIR" ]; then
        find "$OUTPUT_DIR" -maxdepth 1 -type f -print | sort
    fi
    echo "============================================================"
}
trap 'on_exit $?' EXIT

echo "============================================================"
echo "Multi-dataset reconstruction smoke"
echo "Job id: ${SLURM_JOB_ID:-manual}"
echo "Host: $(hostname)"
echo "Start: $(date)"
echo "Project: $PROJECT_DIR"
echo "Datasets: $DATASETS"
echo "Models: $MODELS"
echo "LLMs: $LLMS"
echo "Experiments: $EXPERIMENTS"
echo "Targets per dataset/model: $NUM_TARGET_NODES"
echo "Output dir: $OUTPUT_DIR"
echo "============================================================"

cd "$PROJECT_DIR"
mkdir -p "$OUTPUT_DIR"

if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
    source "$HOME/miniconda3/etc/profile.d/conda.sh"
else
    echo "ERROR: Could not find conda.sh at $HOME/miniconda3/etc/profile.d/conda.sh" >&2
    exit 2
fi
conda activate "$CONDA_ENV"

export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-8}"
export MKL_NUM_THREADS="${SLURM_CPUS_PER_TASK:-8}"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"

export HF_HOME="${HF_HOME:-/scratch-shared/$USER/huggingface}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-$HF_HOME/transformers}"
export HF_DATASETS_CACHE="${HF_DATASETS_CACHE:-$HF_HOME/datasets}"
export HUGGINGFACE_HUB_CACHE="${HUGGINGFACE_HUB_CACHE:-$HF_HOME/hub}"
mkdir -p "$HF_HOME" "$TRANSFORMERS_CACHE" "$HF_DATASETS_CACHE" "$HUGGINGFACE_HUB_CACHE"

CONTINUE_ON_ERROR_ARGS=()
case "${CONTINUE_ON_LLM_ERROR,,}" in
    1|true|yes|y)
        CONTINUE_ON_ERROR_ARGS=(--continue-on-llm-error)
        ;;
esac

THINKING_BUDGET_ARGS=()
if [ -n "$THINKING_BUDGET" ]; then
    THINKING_BUDGET_ARGS=(--thinking-budget "$THINKING_BUDGET")
fi

ENABLE_THINKING_ARGS=()
case "${ENABLE_THINKING,,}" in
    1|true|yes|y)
        ENABLE_THINKING_ARGS=(--enable-thinking)
        ;;
esac

DISABLE_THINKING_ARGS=()
case "${DISABLE_THINKING,,}" in
    1|true|yes|y)
        DISABLE_THINKING_ARGS=(--disable-thinking)
        ENABLE_THINKING_ARGS=()
        THINKING_BUDGET_ARGS=()
        ;;
esac

python -m py_compile \
    Final_version/main.py \
    Final_version/LLM_Module.py \
    Final_version/Extracion.py \
    Final_version/Evalueation.py

python Final_version/main.py --dry-run \
    --datasets "${DATASET_ARGS[@]}" \
    --models "${MODEL_ARGS[@]}" \
    --llms "${LLM_ARGS[@]}" \
    --experiments "${EXPERIMENT_ARGS[@]}" \
    --num-target-nodes "$NUM_TARGET_NODES" \
    --target-node-pool "$TARGET_NODE_POOL" \
    --target-node-sampling "$TARGET_NODE_SAMPLING" \
    --num-hops "$NUM_HOPS" \
    --extract-workers "$EXTRACT_WORKERS" \
    --device "$DEVICE" \
    --seed "$SEED" \
    --num-runs 1 \
    --max-new-tokens "$MAX_NEW_TOKENS" \
    --llm-batch-size "$LLM_BATCH_SIZE" \
    "${ENABLE_THINKING_ARGS[@]}" \
    "${THINKING_BUDGET_ARGS[@]}" \
    "${DISABLE_THINKING_ARGS[@]}" \
    --reconstruction-max-candidates "$MAX_CANDIDATES" \
    --candidate-context-mode "$CANDIDATE_CONTEXT_MODE" \
    --candidate-pca-components "$CANDIDATE_PCA_COMPONENTS" \
    "${CONTINUE_ON_ERROR_ARGS[@]}" \
    --output-dir "$OUTPUT_DIR"

RUN_PREFIX=()
if command -v timeout >/dev/null 2>&1; then
    RUN_PREFIX=(timeout "$SMOKE_TIMEOUT")
fi

"${RUN_PREFIX[@]}" python Final_version/main.py \
    --datasets "${DATASET_ARGS[@]}" \
    --models "${MODEL_ARGS[@]}" \
    --llms "${LLM_ARGS[@]}" \
    --experiments "${EXPERIMENT_ARGS[@]}" \
    --num-target-nodes "$NUM_TARGET_NODES" \
    --target-node-pool "$TARGET_NODE_POOL" \
    --target-node-sampling "$TARGET_NODE_SAMPLING" \
    --num-hops "$NUM_HOPS" \
    --extract-workers "$EXTRACT_WORKERS" \
    --device "$DEVICE" \
    --seed "$SEED" \
    --num-runs 1 \
    --max-new-tokens "$MAX_NEW_TOKENS" \
    --llm-batch-size "$LLM_BATCH_SIZE" \
    "${ENABLE_THINKING_ARGS[@]}" \
    "${THINKING_BUDGET_ARGS[@]}" \
    "${DISABLE_THINKING_ARGS[@]}" \
    --reconstruction-max-candidates "$MAX_CANDIDATES" \
    --candidate-context-mode "$CANDIDATE_CONTEXT_MODE" \
    --candidate-pca-components "$CANDIDATE_PCA_COMPONENTS" \
    "${CONTINUE_ON_ERROR_ARGS[@]}" \
    --output-dir "$OUTPUT_DIR"

RAW_RESULTS="$OUTPUT_DIR/results_raw_reconstruction_1hop.json"
PROMPT_IO="$OUTPUT_DIR/llm_prompt_io_reconstruction_1hop.json"

if [ ! -f "$RAW_RESULTS" ]; then
    echo "ERROR: missing raw reconstruction results: $RAW_RESULTS" >&2
    exit 4
fi
if [ ! -f "$PROMPT_IO" ]; then
    echo "ERROR: missing prompt I/O file: $PROMPT_IO" >&2
    exit 5
fi

if [ "${VERIFY_DATASETS,,}" = "true" ]; then
    python - "$RAW_RESULTS" "$DATASETS" <<'PY'
import json
import sys
from pathlib import Path

raw_path = Path(sys.argv[1])
expected = set(sys.argv[2].split())
rows = json.loads(raw_path.read_text())
seen = {str(row.get("dataset")) for row in rows}
missing = expected - seen
print("Raw rows:", len(rows))
print("Datasets seen:", sorted(seen))
if missing:
    raise SystemExit(f"Missing expected dataset(s) in raw results: {sorted(missing)}")
print("Rows with LLM errors:", sum(1 for row in rows if row.get("llm_error")))
print("Rows with filtered invalid ids:", sum(1 for row in rows if row.get("invalid_predicted_neighbors")))
PY
fi

echo "Summary:"
cat "$OUTPUT_DIR/results_summary_reconstruction_1hop.json"
echo
echo "Multi-dataset smoke completed successfully."
