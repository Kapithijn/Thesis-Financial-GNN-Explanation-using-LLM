#!/bin/bash
#SBATCH --job-name=gnn_elliptic_full_3runs_256
#SBATCH --output=snellius_%x_%A_%a.out
#SBATCH --error=snellius_%x_%A_%a.err
#SBATCH --array=0-4                  # 5 tasks: one per LLM
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=180G
#SBATCH --gpus=1
#SBATCH --time=24:00:00
#SBATCH --partition=gpu_h100

# Notifications
#SBATCH --mail-type=FAIL,END,TIME_LIMIT
#SBATCH --mail-user=thijn.van.veen@student.uva.nl

set -Eeuo pipefail

###############################################################################
# Tunable parameters
###############################################################################

# NOTE: Parallel extraction workers >1 can increase RAM use.
# Start with 1 and increase only if stable.
EXTRACT_WORKERS=1
NUM_TARGET_NODES=100
NUM_HOPS=2
DEVICE="cuda"
SEED=42
NUM_RUNS=3
MAX_NEW_TOKENS=256
LLM_BATCH_SIZE=1

# No external config file is used.
# The pipeline runs with built-in defaults from `Final_version/main.py`,
# then these CLI flags override selected values.

# Map array index to LLM names
LLMS=(
    "Qwen/Qwen2.5-3B"
    "Qwen/Qwen3.5-4B"
    "Qwen/Qwen3.5-9B"
    "Qwen/Qwen3.5-27B"
    "Qwen/Qwen3.5-35B-A3B"
)
LLM="${LLMS[$SLURM_ARRAY_TASK_ID]}"

# Datasets and models to run
# Note: `Final_version/main.py` loads data relative to `Final_version/data/`.
# For DGraphFin you need: `Final_version/data/dgraphfin_dataset/raw/DGraphFin.zip` (or a symlink).
# If you want DGraphFin too, set: DATASETS=("dgraph" "elliptic")
DATASETS=("elliptic")
MODELS=("GCN" "GAT" "GIN" "GraphSAGE")
EXPERIMENTS=(
    "embedding_classification"
    "embedding_classification_explainer_subgraph"
    "raw_graph_reasoning"
    "reconstruction_1hop"
    "reconstruction_1hop_embed_expl"
    "reconstruction_1hop_no_gnn"
    "baseline_random"
    "baseline_cosine"
    "baseline_feature"
)

# Paths - edit to match where you cloned the repo on Snellius
PROJECT_DIR="/scratch-shared/$USER/Explanation-of-GNN-using-LLM"
cd "$PROJECT_DIR" || { echo "Project dir not found: $PROJECT_DIR"; exit 1; }

###############################################################################
# Conda environment
###############################################################################

# Conda is used directly; no modules are loaded.
source "$HOME/miniconda3/etc/profile.d/conda.sh"
conda activate ethfraud_clean

###############################################################################
# Performance / cache settings
###############################################################################

export OMP_NUM_THREADS=$SLURM_CPUS_PER_TASK
export MKL_NUM_THREADS=$SLURM_CPUS_PER_TASK
export TOKENIZERS_PARALLELISM=false

# Put HuggingFace cache on scratch to avoid home-quota issues and repeated downloads.
export HF_HOME="/scratch-shared/$USER/huggingface"
export TRANSFORMERS_CACHE="$HF_HOME/transformers"
export HF_DATASETS_CACHE="$HF_HOME/datasets"
export HUGGINGFACE_HUB_CACHE="$HF_HOME/hub"
mkdir -p "$HF_HOME"

mkdir -p "$PROJECT_DIR/outputs"

# One folder for the whole array submission, with per-task subfolders.
# `Final_version/main.py` will then create per-run subfolders inside this OUTDIR
# when `--num-runs > 1` (e.g. OUTDIR/run_1, OUTDIR/run_2, ...).
RUN_ROOT="$PROJECT_DIR/outputs/${SLURM_ARRAY_JOB_ID:-$SLURM_JOB_ID}"
OUTDIR="$RUN_ROOT/task_${SLURM_ARRAY_TASK_ID}"
mkdir -p "$OUTDIR"

# Build the exact stderr path so we can tail it on failure.
ERR_LOG="$SLURM_SUBMIT_DIR/snellius_${SLURM_JOB_NAME}_${SLURM_ARRAY_JOB_ID}_${SLURM_ARRAY_TASK_ID}.err"

on_exit() {
    exit_code=$1
    if [ "$exit_code" -ne 0 ]; then
        {
            echo "============================================================"
            echo "JOB FAILED"
            echo "Exit code: $exit_code"
            echo "Time: $(date)"
            echo "Host: $(hostname)"
            echo "SLURM_JOB_ID: ${SLURM_JOB_ID:-unknown}"
            echo "SLURM_ARRAY_JOB_ID: ${SLURM_ARRAY_JOB_ID:-unknown}"
            echo "SLURM_ARRAY_TASK_ID: ${SLURM_ARRAY_TASK_ID:-unknown}"
            echo "============================================================"
            if [ -f "$ERR_LOG" ]; then
                echo "Last 100 lines of stderr:"
                tail -n 100 "$ERR_LOG"
            fi
        } >&2
    fi
}
trap 'on_exit $?' EXIT

echo "Starting job: SLURM_JOB_ID=$SLURM_JOB_ID ARRAY_TASK=$SLURM_ARRAY_TASK_ID"
echo "Node: $(hostname)"
echo "Python: $(which python)"
python --version

echo "GPU info:"
nvidia-smi

DATASETS_ARG="${DATASETS[*]}"
MODELS_ARG="${MODELS[*]}"
EXPERIMENTS_ARG="${EXPERIMENTS[*]}"

echo "LLM=${LLM}  Datasets=${DATASETS_ARG}  Models=${MODELS_ARG}  Targets=${NUM_TARGET_NODES}  Runs=${NUM_RUNS}"
echo "Experiments=${EXPERIMENTS_ARG}"
echo "Max new tokens=${MAX_NEW_TOKENS}"
echo "LLM batch size=${LLM_BATCH_SIZE}"
echo "Output dir: ${OUTDIR}"

python Final_version/main.py \
    --datasets $DATASETS_ARG \
    --models $MODELS_ARG \
    --llms "$LLM" \
    --experiments $EXPERIMENTS_ARG \
    --num-target-nodes $NUM_TARGET_NODES \
    --target-node-pool test \
    --num-hops $NUM_HOPS \
    --extract-workers $EXTRACT_WORKERS \
    --device $DEVICE \
    --seed $SEED \
    --num-runs $NUM_RUNS \
    --max-new-tokens $MAX_NEW_TOKENS \
    --llm-batch-size $LLM_BATCH_SIZE \
    --output-dir "$OUTDIR"

echo "Job finished: $SLURM_JOB_ID:$SLURM_ARRAY_TASK_ID"
